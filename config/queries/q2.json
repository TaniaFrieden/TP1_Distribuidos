{
  "skip_gateway_output": true,
  "banks_shard": {
    "queue_shard_prefix": "q2_shard_banks",
    "total_workers": 6,
    "hash_field": "Bank ID"
  },
  "workers": [
    {
      "type": "projection",
      "prefix": "q2_projection",
      "replicas": 6,
      "input_queue": "q2_pre_projection",
      "output_queue": [
        {
          "queue_shard_prefix": "q2_shard_transactions",
          "total_workers": 6,
          "hash_field": "From Bank"
        }
      ],
      "extra_env": {
        "CAMPOS": "From Bank,Account,Payment Currency,Receiving Currency,Amount Received,Amount Paid",
        "INT_FIELDS": "From Bank"
      }
    },
    {
      "type": "bank_shard",
      "prefix": "q2_agregador_shard",
      "replicas": 6,
      "input_queue": [
        "q2_shard_transactions",
        "q2_shard_banks"
      ],
      "output_queue": "q2_results"
    }
  ]
}
