{
  "skip_gateway_output": true,
  "workers": [
    {
      "type": "projection",
      "prefix": "q4_projection",
      "replicas": 2,
      "input_queue": "q4_pre_projection",
      "output_queue": "q4_projected",
      "extra_env": {
        "CAMPOS": "From Bank,Account,To Bank,Account.1,Timestamp",
        "INT_FIELDS": ""
      }
    },
    {
      "type": "filter",
      "prefix": "q4_filter_period",
      "replicas": 2,
      "input_queue": "q4_projected",
      "output_queue": [
        {"queue_shard_prefix": "q4_to_sumador", "total_workers": 3, "hash_fields": ["From Bank", "Account"]},
        {"queue_shard_prefix": "q4_to_joiner",  "total_workers": 3, "hash_fields": ["From Bank", "Account"]}
      ],
      "extra_env": {
        "FILTER_FIELD": "Timestamp",
        "FILTER_VALUE": "2022/09/01, 2022/09/05",
        "FILTER_OPERATOR": "between"
      }
    },
    {
      "type": "group_distinct_counter",
      "prefix": "q4_sumador",
      "replicas": 3,
      "input_queue": "q4_to_sumador_{id}",
      "output_queue": [
        {"queue_shard_prefix": "q4_scatter_edges", "total_workers": 3, "hash_fields": ["to_bank", "to_account"]}
      ],
      "extra_env": {
        "GROUP_FIELDS": "From Bank,Account",
        "GROUP_OUTPUT_FIELDS": "from_bank,from_account",
        "VALUE_FIELDS": "To Bank,Account.1",
        "VALUE_OUTPUT_FIELDS": "to_bank,to_account",
        "EXPECTED_COUNT": "5",
        "EMIT_MODE": "explode"
      }
    },
    {
      "type": "joiner_q4",
      "prefix": "q4_joiner",
      "replicas": 3,
      "input_queue": ["q4_scatter_edges_{id}", "q4_to_joiner_{id}"],
      "output_queue": [
        {"queue_shard_prefix": "q4_paths", "total_workers": 3, "hash_fields": ["a_bank", "a_account", "c_bank", "c_account"]}
      ]
    },
    {
      "type": "group_distinct_counter",
      "prefix": "q4_contador",
      "replicas": 3,
      "input_queue": "q4_paths_{id}",
      "output_queue": "q4_results",
      "extra_env": {
        "GROUP_FIELDS": "a_bank,a_account,c_bank,c_account",
        "GROUP_OUTPUT_FIELDS": "From Bank,From Account,To Bank,To Account",
        "VALUE_FIELDS": "b_bank,b_account",
        "EXPECTED_COUNT": "5",
        "EMIT_MODE": "aggregate",
        "COUNT_OUTPUT_FIELD": "Amount Transactions"
      }
    }
  ]
}
